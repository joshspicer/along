# Public, non-secret deployment settings
ALONG_ENV=production
ALONG_DOMAIN=along.spicer.dev
APPLE_TEAM_ID=N7C8DEK852
ANDROID_SIGNING_SHA256=
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=720h
RATE_LIMIT_PER_MINUTE=120

# APNs identifiers (the .p8 itself is a Docker secret)
APNS_TEAM_ID=REPLACE_WITH_APPLE_TEAM_ID
APNS_KEY_ID=REPLACE_WITH_APNS_KEY_ID
APNS_ENVIRONMENT=production

# Secret file paths; files are ignored by git
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
DATABASE_URL_FILE=./secrets/database_url
JWT_SIGNING_KEY_FILE=./secrets/jwt_signing_key
PUSH_ENCRYPTION_KEY_FILE=./secrets/push_encryption_key
APNS_KEY_FILE=./secrets/AuthKey.p8
BACKUP_UPLOAD_TOKEN_FILE=./secrets/backup_upload_token

# Encrypted off-host backups
BACKUP_AGE_RECIPIENT=age1REPLACE_WITH_OFFSITE_RECIPIENT
BACKUP_UPLOAD_URL=https://backup-gateway.example/along-production
BACKUP_RETENTION_DAYS=7
